store.description.baking = "• الخبز
يمكنك نقل بيانات الرؤوس مثل اللون والخشونة والمعادن وتفاصيل صغيرة الحجم إلى القوام. 
يمكنك أيضًا عكس العملية، وضيع بيانات القوام في بيانات الرؤوس أو الطبقات.";
store.description.dynamic = "• الطبوغرافيا الديناميكية
قم بتحسين محلي لشبكتك تحت فرشاتك للحصول على مستوى تفصيل تلقائي.
يمكنك حتى الاحتفاظ بطبقاتك، لأنها ستتم تحديثها تلقائيًا!";
store.description.files = "• التصدير والاستيراد
تشمل التنسيقات المدعومة ملفات glTF وOBJ وSTL وPLY.";
store.description.group = "• مجموعة الأوجه
أفصل شبكتك إلى مجموعات فرعية باستخدام أداة مجموعة الأوجه.";
store.description.interface = "• واجهة مستخدم
واجهة مستخدم سهلة الاستخدام، مصممة لتجربة الهاتف المحمول.
يمكن التخصيص أيضًا!";
store.description.layer = "• الطبقات
سجل عمليات النحت والطلاء الخاصة بك في طبقات منفصلة لتسهيل التكرار أثناء عملية الإنشاء.
يتم تسجيل كل من تغييرات النحت والطلاء.";
store.description.multires = "• نحت متعدد الدقة
تنقل بين عدة دقة لشبكتك لمرونة عالية في سير العمل.";
store.description.paint = "• أدوات الطلاء
رسم الرؤوس باستخدام اللون والخشونة والمعادن.
يمكنك بسهولة إدارة جميع إعدادات المواد.";
store.description.postprocess = "• معالجة لاحقة
انعكاس مساحة الشاشة، عمق الميدان، تظليل المحيط، تعيين النغمات، إلخ";
store.description.primitive = "• الشكل البدائي
يمكن استخدام الأسطوانة، الطوق، الأنبوب، المخرطة وغيرها من الأشكال البدائية لبدء الأشكال الجديدة بسرعة من البداية.";
store.description.remesher = "• Quad Remesher (شراء داخل التطبيق منفصل فقط)
قم بإعادة تشكيل الكائن تلقائيًا باستخدام شبكة رباعية تتبع انحناءات الشبكة.
يدعم الأدلة، مجموعات الوجه ودهان الكثافة.";
store.description.rendering = "• عرض PBR
عرض PBR جميل افتراضيًا، مع إضاءة وظلال.
يمكنك دائمًا التحويل إلى MatCap للحصول على تظليل أكثر معيارية لأغراض النحت.";
store.description.sculpt = "• أدوات النحت
الطين، التسطيح، التنعيم، القناع والعديد من الفُرش الأخرى ستمكنك من تشكيل إبداعك.
يمكنك أيضًا استخدام أداة القطع البوليانية مع اللاسو، المستطيل وأشكال أخرى لأغراض الأسطح الصلبة.";
store.description.stroke = "• تخصيص ضربات القلم
يمكن تخصيص تدرج الضربات، ألفا، التلبيس، ضغط القلم والمعلمات الأخرى للضربات.
يمكنك حفظ وإعادة تحميل إعدادات أدواتك أيضًا.";
store.description.topology = "• تقليل
قلل عدد الأوجه مع الحفاظ على أكبر قدر ممكن من التفاصيل.";
store.description.unwrap = "• فك رباط UV تلقائي
يمكن للفك الرباط التلقائي استخدام مجموعات الأوجه للتحكم في عملية الفك.";
store.description.voxel = "• إعادة تشكيل Voxel
أعد تشكيل شبكتك بسرعة للحصول على مستوى تفصيل موحد.
يمكن استخدامه لرسم شكل خشن في بداية عملية الإنشاء.";
store.headline = "انحت وزين وأنشئ في بيئة ثلاثية الأبعاد";
// app store main page
store.name = "نوماد سكلبت";
store.steam = "Nomad Sculpt هو تطبيق نحت ثلاثي الأبعاد مصمم للسرعة والبساطة.
يمكنك الرسم، والتشكيل، وصقل الأشكال بشكل طبيعي، سواء عند وضع الأفكار الأساسية أو العمل على التفاصيل الدقيقة.

• فُرش النحت (طين، تسطيح، تنعيم، قناع، تشذيب، إلخ)
• الطوبولوجيا الديناميكية وإعادة تشكيل الشبكة باستخدام Voxel لسير عمل مرن
• النحت متعدد الدقة
• نظام Layer للنحت والرسم
• طلاء الرؤوس (اللون، Roughness، Metalness)
• فُرش قابلة للتخصيص بالكامل (Alpha، التدرّج، الضغط، التبليط)
• أشكال بدائية (أنبوب، مخرطة، أسطوانة، طورس…)
• فكّ التفاف UV تلقائيًا (مع دعم مجموعات الوجوه)
• Baking (الرؤوس ↔ القوام)
• تقليل المضلعات
• مجموعات الوجوه لتقسيم Mesh
• عرض PBR + MatCap + ما بعد المعالجة
• استيراد/تصدير (glTF، OBJ، FBX، STL، PLY)";
store.tag = "انحت، ثلاثي الأبعاد، رحالة، طلاء، تصميم";

